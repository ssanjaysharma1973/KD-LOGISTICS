#!/usr/bin/env python3
"""
Query gps_live_data from the Streamlit SQLite DB and print JSON array of {lat,lng,ts}.
Usage: query_track.py <db_path> <vehicle_id> <from_iso_or_empty> <to_iso_or_empty> <client_id_or_empty>
"""
import sys, json, sqlite3, os, re

def normalize(v):
    if v is None:
        return ''
    return re.sub(r'[^A-Z0-9]', '', str(v).upper())

def main():
    if len(sys.argv) < 2:
        print('[]')
        return
    db_path = sys.argv[1]
    vehicle_id = sys.argv[2] if len(sys.argv) > 2 else ''
    from_ts = sys.argv[3] if len(sys.argv) > 3 and sys.argv[3] not in ('', 'null', 'None') else None
    to_ts = sys.argv[4] if len(sys.argv) > 4 and sys.argv[4] not in ('', 'null', 'None') else None
    client_id = sys.argv[5] if len(sys.argv) > 5 and sys.argv[5] not in ('', 'null', 'None') else None

    if not os.path.exists(db_path):
        print('[]')
        return
    try:
        conn = sqlite3.connect(db_path)
        conn.row_factory = sqlite3.Row
        cur = conn.cursor()

        # try best-effort matching: exact vehicle_number, normalized match, or LIKE
        params = []
        where = []
        # inspect columns to avoid referencing non-existent columns
        cols = [c[1] for c in cur.execute("PRAGMA table_info('gps_live_data')").fetchall()]
        if vehicle_id:
            # first try exact -- include device_number only if present
            if 'device_number' in cols:
                where.append('(vehicle_number = ? OR device_number = ?)')
                params.extend([vehicle_id, vehicle_id])
            else:
                where.append('(vehicle_number = ?)')
                params.append(vehicle_id)
        if client_id:
            where.append('client_id = ?')
            params.append(client_id)
        if from_ts and to_ts:
            where.append('gps_time BETWEEN ? AND ?')
            params.extend([from_ts, to_ts])
        elif from_ts:
            where.append('gps_time >= ?')
            params.append(from_ts)
        elif to_ts:
            where.append('gps_time <= ?')
            params.append(to_ts)

        base_q = 'SELECT vehicle_number, latitude AS lat, longitude AS lng, gps_time AS ts FROM gps_live_data'
        q = base_q
        if where:
            q += ' WHERE ' + ' AND '.join(where)
        q += ' ORDER BY ts ASC LIMIT 10000'

        try:
            rows = cur.execute(q, params).fetchall()
        except Exception:
            # fallback queries if above didn't return meaningful results
            rows = []

        # If no rows, try normalized comparison
        if not rows and vehicle_id:
            norm = normalize(vehicle_id)
            q2 = base_q + " WHERE UPPER(REPLACE(REPLACE(vehicle_number, ' ', ''), '-', '')) = ?"
            if client_id:
                q2 += ' AND client_id = ?'
                rparams = [norm, client_id]
            else:
                rparams = [norm]
            if from_ts:
                q2 += ' AND gps_time >= ?'
                rparams.append(from_ts)
            if to_ts:
                q2 += ' AND gps_time <= ?'
                rparams.append(to_ts)
            q2 += ' ORDER BY ts ASC LIMIT 10000'
            try:
                rows = cur.execute(q2, rparams).fetchall()
            except Exception:
                rows = []

        # If still no rows, try LIKE
        if not rows and vehicle_id:
            like = f"%{vehicle_id}%"
            q3 = base_q + " WHERE vehicle_number LIKE ?"
            rparams = [like]
            if client_id:
                q3 += ' AND client_id = ?'
                rparams.append(client_id)
            if from_ts:
                q3 += ' AND gps_time >= ?'
                rparams.append(from_ts)
            if to_ts:
                q3 += ' AND gps_time <= ?'
                rparams.append(to_ts)
            q3 += ' ORDER BY ts ASC LIMIT 10000'
            try:
                rows = cur.execute(q3, rparams).fetchall()
            except Exception:
                rows = []

        out = []
        for r in rows:
            try:
                lat = r['lat'] if r['lat'] is not None else None
                lng = r['lng'] if r['lng'] is not None else None
                ts = r['ts']
                if lat is None or lng is None:
                    continue
                out.append({'lat': float(lat), 'lng': float(lng), 'ts': ts})
            except Exception:
                continue

        print(json.dumps(out))
    except Exception:
        print('[]')

if __name__ == '__main__':
    main()
